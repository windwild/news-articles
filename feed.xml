---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ site.title }}</title>
    <description>{{ site.description }}</description>
    <link>{{ site.url }}{{ site.baseurl }}/</link>
    <atom:link href="{{ site.url }}{{ site.baseurl }}/feed.xml" rel="self" type="application/rss+xml"/>

    {% assign all_articles = "" | split: "" %}
    {% for article in site.openai %}{% assign all_articles = all_articles | push: article %}{% endfor %}
    {% for article in site.anthropic %}{% assign all_articles = all_articles | push: article %}{% endfor %}
    {% for article in site.vercel %}{% assign all_articles = all_articles | push: article %}{% endfor %}
    {% for article in site.langchain %}{% assign all_articles = all_articles | push: article %}{% endfor %}
    {% assign sorted = all_articles | sort: "date" | reverse %}

    {% for post in sorted limit:30 %}
    <item>
      <title>{{ post.title | xml_escape }}</title>
      <link>{{ site.url }}{{ site.baseurl }}{{ post.url }}</link>
      <guid isPermaLink="true">{{ site.url }}{{ site.baseurl }}{{ post.url }}</guid>
      <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
      <description>{{ post.description | default: post.excerpt | xml_escape | truncate: 300 }}</description>
      {% for tag in post.tags %}
      <category>{{ tag | xml_escape }}</category>
      {% endfor %}
      <category>{{ post.source_name | default: post.collection | xml_escape }}</category>
    </item>
    {% endfor %}
  </channel>
</rss>
